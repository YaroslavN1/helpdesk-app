{
  "name": "server",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "db:generate": "bun --bun run prisma generate",
    "db:migrate": "bun --bun run prisma migrate dev",
    "db:push": "bun --bun run prisma db push",
    "db:studio": "bun --bun run prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^5.8.0"
  }
}
